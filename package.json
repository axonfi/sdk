{
  "name": "@axonfi/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Axon — treasury and payment infrastructure for autonomous AI agents",
  "license": "MIT",
  "author": "Axon",
  "homepage": "https://axonfi.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/axonfi/axon.git",
    "directory": "packages/sdk-ts"
  },
  "keywords": [
    "axon",
    "ai-agents",
    "payments",
    "eip-712",
    "usdc",
    "base",
    "viem"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "viem": "^2.46.2"
  },
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0"
  }
}
